# Configuración de InfluxDB en AWS Timestream
# Actualiza estos valores después de ejecutar 'terraform apply'

# El endpoint lo obtienes del output 'influxdb_endpoint' de Terraform
INFLUXDB_URL=https://your-influxdb-endpoint.timestream-influxdb.us-east-1.amazonaws.com

# Token de autenticación (lo generas desde la consola de AWS o mediante API)
# Sigue esta guía: https://docs.aws.amazon.com/timestream/latest/developerguide/InfluxDB.API.html
INFLUXDB_TOKEN=your-admin-token-here

# Organización y bucket definidos en terraform.auto.tfvars
INFLUXDB_ORG=homelab
INFLUXDB_BUCKET=cluster_metrics
