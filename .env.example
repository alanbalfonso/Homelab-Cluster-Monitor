# ==============================================
# HCM - Variables de Entorno (Template)
# ==============================================
# Copia este archivo a .env y configura los valores apropiados

# ==============================================
# PostgreSQL Configuration
# ==============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=homelab_monitor
DB_USER=admin
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# PostgreSQL Docker Environment
POSTGRES_DB=homelab_monitor
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ==============================================
# Backend API Configuration
# ==============================================
PORT=3000
NODE_ENV=development
API_URL=http://backend:3000

# ==============================================
# Simulator Configuration
# ==============================================
BACKEND_URL=http://backend:3000
METRICS_INTERVAL=30000

# ==============================================
# Frontend Configuration
# ==============================================
FRONTEND_PORT=8080

# ==============================================
# Redis (opcional - para futuras mejoras)
# ==============================================
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ==============================================
# JWT & Security (opcional - para futuras mejoras)
# ==============================================
# JWT_SECRET=generate-a-secure-random-string-here
# JWT_EXPIRES_IN=24h
# CORS_ORIGIN=http://localhost:8080

# ==============================================
# Email Alerts (opcional - para futuras mejoras)
# ==============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# ALERT_EMAIL_TO=admin@example.com

# ==============================================
# Monitoring & Logging (opcional)
# ==============================================
# LOG_LEVEL=info
# SENTRY_DSN=

# ==============================================
# CI/CD (Docker Hub + AWS EKS)
# ==============================================
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-access-token
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
EKS_CLUSTER_NAME=Homelab-Cluster-Monitor
